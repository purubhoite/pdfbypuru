generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Analytics {
  id         Int      @id @default(autoincrement())
  totalEdits Int      @default(0)
  updatedAt  DateTime @updatedAt
}
